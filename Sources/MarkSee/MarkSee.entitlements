<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        MarkSee is a sandboxed, read-only document viewer.

        Hardened Runtime is required for notarization.
        Sandbox is enabled for best security posture; the only
        capability needed is reading user-selected files, which is
        granted automatically by the system when the user opens a file
        via the file picker or drag-and-drop (no explicit entitlement
        needed for that).
    -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Allow read-only access to the entire file system so the app
         can open markdown files passed on the command line or via
         Finder "Open With". Remove if you want stricter sandboxing
         and only allow user-selected files. -->
    <key>com.apple.security.files.user-selected.read-only</key>
    <true/>
</dict>
</plist>
